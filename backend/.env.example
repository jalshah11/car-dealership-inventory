# Copy this file to .env and fill in real values.
# NEVER commit the real .env file -- it's already in .gitignore.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/car_dealership?schema=public"

# Server
PORT=4000
NODE_ENV=development

# JWT
# Use a long, random string in real environments (e.g. `openssl rand -hex 32`)
JWT_SECRET="replace-with-a-strong-random-secret"
JWT_EXPIRES_IN="1d"
