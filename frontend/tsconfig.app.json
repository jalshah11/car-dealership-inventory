{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path alias -- mirrors resolve.alias in vite.config.ts. Vite's alias
       makes '@/...' imports actually RESOLVE at bundle time; this makes
       the TypeScript language server (and tsc type-checking) understand
       them too. Two separate tools, two separate configs, same lesson we
       already learned on the backend with tsconfig-paths.
       (No separate baseUrl needed -- modern TypeScript resolves `paths`
       relative to this config file's own location automatically; baseUrl
       is deprecated as of TS 7.) */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
